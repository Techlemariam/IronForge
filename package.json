{
  "version": "1.0.0",
  "name": "ironforge-rpg",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:smoke": "playwright test --grep @smoke",
    "test:exhaustive": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "postinstall": "prisma generate",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit",
    "security": "pnpm audit || echo 'Audit failed'",
    "agent:verify": "turbo run lint build security",
    "ship": "pwsh ./scripts/ship.ps1",
    "test:watch": "vitest",
    "ci:l1": "turbo run lint check-types test --filter=...[origin/main]",
    "ci:l2": "turbo run build test:smoke",
    "ci:l3": "turbo run security test:exhaustive",
    "agent:format": "npx prettier --write .",
    "agent:types": "npx prisma generate",
    "agent:build": "turbo run build",
    "agent:test": "turbo run test",
    "agent:lint": "turbo run lint",
    "test:docker:down": "docker-compose -f docker-compose.test.yml down",
    "test:integration": "npm run test:docker:up && dotenv -e .env.test -- npx prisma db push --accept-data-loss && dotenv -e .env.test -- vitest run --config vitest.integration.config.ts",
    "test:visual": "npx playwright test visual.spec.ts",
    "lhci": "lhci autorun",
    "docs:generate": "typedoc",
    "clean:logs": "npx tsx scripts/clean-logs.ts",
    "infra:check": "npx tsx scripts/check-infra.ts",
    "prebuild": "npm run clean:logs",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset",
    "supabase:status": "npx supabase status",
    "ai:local": "pwsh c:/Users/alexa/Workspaces/toggle-llm.ps1 local",
    "ai:entropy": "pwsh c:/Users/alexa/Workspaces/toggle-llm.ps1 entropy"
  },

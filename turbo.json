{
    "$schema": "https://turbo.build/schema.json",
    "globalEnv": [
        "SKIP_ENV_VALIDATION",
        "DATABASE_URL",
        "DIRECT_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY"
    ],
    "tasks": {
        "build": {
            "outputs": [
                ".next/**",
                "!.next/cache/**"
            ],
            "dependsOn": [
                "^build"
            ],
            "env": [
                "DATABASE_URL",
                "DIRECT_URL",
                "SKIP_ENV_VALIDATION"
            ]
        },
        "test": {
            "dependsOn": [],
            "outputs": [
                "coverage/**"
            ],
            "inputs": [
                "src/**/*.tsx",
                "src/**/*.ts",
                "test/**/*.ts"
            ],
            "env": [
                "DATABASE_URL",
                "DIRECT_URL"
            ]
        },
        "lint": {
            "inputs": [
                "src/**/*.tsx",
                "src/**/*.ts",
                ".eslintrc.json"
            ]
        },
        "check-types": {
            "inputs": [
                "src/**/*.tsx",
                "src/**/*.ts",
                "tsconfig.json"
            ]
        },
        "security": {
            "inputs": [
                "package.json",
                "pnpm-lock.yaml"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
# Database (Supabase / PostgreSQL)
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Auth (Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://..."
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Integrations
INTERVALS_API_KEY="your_api_key"
INTERVALS_ATHLETE_ID="i12345"
HEVY_API_KEY="your_hevy_token"

# Strava (Optional)
STRAVA_CLIENT_ID="123456"
STRAVA_CLIENT_SECRET="your_secret"

# Sentry (Monitoring)
SENTRY_DSN="https://..."
SENTRY_ORG="your_org"
SENTRY_PROJECT="ironforge-rpg"
SENTRY_AUTH_TOKEN="your_auth_token"

# Vercel MCP
VERCEL_TOKEN="your_vercel_token"
VERCEL_ORG_ID="your_org_id"
VERCEL_PROJECT_ID="your_project_id"

# Supabase MCP (Server-side Only)
SUPABASE_SERVICE_KEY="your_service_role_key"
SUPABASE_PROJECT_REF="your_project_ref"

# Google Maps Platform MCP
GOOGLE_MAPS_API_KEY="your_api_key"

# GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN="your_personal_access_token"

# Figma MCP (Framelink)
FIGMA_API_KEY="figd_your_figma_personal_access_token"

# =============================================================================
# REMOTE TRIGGER & INFRASTRUCTURE
# =============================================================================

# Remote Trigger (n8n / Moltbot)
REMOTE_TRIGGER_SECRET="your_secure_random_string"

# Coolify (Self-hosted deployment)
COOLIFY_URL="https://coolify.your-domain.com"
COOLIFY_API_TOKEN="your_coolify_api_token"
COOLIFY_APP_ID="your_app_id"

# n8n (Workflow automation)
N8N_WEBHOOK_URL="https://n8n.your-tailnet.ts.net/webhook/ironforge-trigger"
N8N_API_KEY="your_n8n_api_key"

# Moltbot (Discord/Slack bot)
DISCORD_BOT_TOKEN="your_discord_bot_token"

# Cron Authentication
CRON_SECRET="your_cron_secret"

# Code Quality
CODECOV_TOKEN="your_codecov_token"

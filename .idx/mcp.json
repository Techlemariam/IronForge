{
  "mcpServers": {
    "stitch": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/stitch-mcp-server"
      ],
      "env": {
        "GOOGLE_API_KEY": "${env:GOOGLE_API_KEY}"
      }
    },
    "figma": {
      "command": "npx",
      "args": [
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "env": {
        "FIGMA_API_KEY": "${env:FIGMA_API_KEY}"
      }
    },
    "n8n": {
      "command": "node",
      "args": [
        "apps/mcp-n8n/build/index.js"
      ],
      "env": {
        "N8N_API_KEY": "${env:N8N_API_KEY}",
        "N8N_HOST": "https://ironforge-coolify.tailafb692.ts.net"
      }
    },
    "n8n-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "supergateway",
        "--streamableHttp",
        "https://ironforge-coolify.tailafb692.ts.net/mcp-server/http",
        "--header",
        "authorization:Bearer ${env:N8N_MCP_TOKEN}"
      ],
      "env": {
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${env:DIRECT_URL}"
      ]
    },
    "sentry": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sentry"
      ],
      "env": {
        "SENTRY_AUTH_TOKEN": "${env:SENTRY_AUTH_TOKEN}",
        "SENTRY_ORG": "${env:SENTRY_ORG}",
        "SENTRY_PROJECT": "${env:SENTRY_PROJECT}"
      }
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--access-token",
        "${env:SUPABASE_ACCESS_TOKEN}"
      ]
    },
    "google-maps": {
      "command": "npx",
      "args": [
        "-y",
        "@googlemaps/code-assist-mcp@latest"
      ],
      "env": {
        "SOURCE": "antigravity"
      }
    },
    "perplexity": {
      "command": "npx",
      "args": [
        "-y",
        "server-perplexity-ask"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${env:PERPLEXITY_API_KEY}"
      }
    },
    "ironforge-factory": {
      "command": "node",
      "args": [
        "mcp/factory-server/build/index.js"
      ],
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}",
        "REPO_OWNER": "Techlemariam",
        "REPO_NAME": "IronForge"
      }
    }
  }
}
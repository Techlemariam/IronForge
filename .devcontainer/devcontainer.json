{
    "name": "IronForge Dev",
    "dockerComposeFile": [
        "../docker-compose.yml"
    ],
    "service": "app-dev",
    "workspaceFolder": "/app",
    "forwardPorts": [
        3000,
        5432
    ],
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22",
            "pnpmVersion": "9.15.0"
        },
        "ghcr.io/devcontainers-contrib/features/doppler-cli:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "postCreateCommand": "pnpm install && npx prisma generate && npx prisma db push",
    "customizations": {
        "vscode": {
            "extensions": [
                "Prisma.prisma",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "bradlc.vscode-tailwindcss",
                "ms-playwright.playwright"
            ],
            "settings": {
                "editor.defaultFormatter": "esbenp.prettier-vscode",
                "editor.formatOnSave": true,
                "typescript.tsdk": "node_modules/typescript/lib"
            }
        }
    },
    "remoteEnv": {
        "DATABASE_URL": "postgresql://postgres:postgres@db:5432/ironforge",
        "DIRECT_URL": "postgresql://postgres:postgres@db:5432/ironforge"
    }
}
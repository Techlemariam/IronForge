# IronForge Agent Environment
# Optimized for ultra-fast workflow execution in GitHub Actions
# syntax=docker/dockerfile:1

# Pinned to node:22-slim@sha256 for supply-chain integrity
FROM node:22-slim@sha256:2fc5ec124496f2fb49b8da251c8b4b674c6b96c1f2176f6c77fa23ec7e9af7d7

# Install system dependencies + PowerShell via Microsoft repo
# Consolidated into a single RUN layer and cleaned up in the same layer to minimise image size
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    ca-certificates \
    gnupg \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /etc/apt/keyrings/microsoft.gpg \
    && echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/microsoft-debian-bookworm-prod bookworm main" > /etc/apt/sources.list.d/microsoft.list \
    && apt-get update && apt-get install -y --no-install-recommends powershell \
    && rm -rf /var/lib/apt/lists/*

# Install pnpm as non-root is not feasible here (corepack operates globally),
# but we still minimise surface by using corepack instead of global npm install
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# Set working directory
WORKDIR /app

# Security: Run as non-root user
RUN addgroup --system --gid 1001 agentgroup \
    && adduser --system --uid 1001 --ingroup agentgroup agent
USER agent

# Set up environment variables for headless execution
ENV CI=true
ENV TERM=dumb
ENV GITHUB_ACTIONS=true

# Entrypoint is not fixed as this image is used as a base for CI steps
CMD ["/usr/bin/pwsh"]

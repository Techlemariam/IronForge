#!/bin/bash
# Pre-commit hook - runs gatekeeper quick check
# Install: cp .agent/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "🚦 Running Gatekeeper (Quick)..."

# Run quick check (types + lint only)
if command -v pwsh &> /dev/null; then
    pwsh .agent/skills/gatekeeper/scripts/verify.ps1 -Quick
else
    bash .agent/skills/gatekeeper/scripts/verify.sh --quick
fi

if [ $? -ne 0 ]; then
    echo "❌ Commit blocked by Gatekeeper"
    echo "   Run: pwsh .agent/skills/gatekeeper/scripts/verify.ps1"
    exit 1
fi

echo "✅ Pre-commit passed"
